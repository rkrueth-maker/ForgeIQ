rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner() {
      return signedIn()
        && request.auth.token.h38Role == 'Owner'
        && request.auth.token.h38Status == 'active'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isOwner());
      allow list: if isOwner();
      allow create, update, delete: if false;
    }
    match /portalInvitations/{id} { allow read, write: if false; }
    match /userAccessAudit/{id} { allow read: if isOwner(); allow write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
