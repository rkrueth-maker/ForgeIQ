{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/business-os-config.schema.json",
  "title": "Business OS Effective Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "engine",
    "businessPack",
    "tenant",
    "environment",
    "releaseChannel",
    "tier",
    "license",
    "controls",
    "featureFlags",
    "modules",
    "roles",
    "theme",
    "catalog",
    "providers",
    "data",
    "externalActionsEnabled"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAt": {"type": "string", "format": "date-time"},
    "engine": {
      "type": "object",
      "required": ["id", "name", "version", "releaseChannels", "defaultReleaseChannel"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "releaseChannels": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "defaultReleaseChannel": {"type": "string"}
      }
    },
    "businessPack": {
      "type": "object",
      "required": ["id", "name", "version"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "version": {"type": "string"}
      }
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "name", "namespace", "mode"],
      "properties": {
        "key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,46}[a-z0-9]$"},
        "name": {"type": "string", "minLength": 1},
        "namespace": {"type": "string", "pattern": "^tenants/[a-z0-9][a-z0-9-]{0,46}[a-z0-9]$"},
        "mode": {"const": "isolated"}
      }
    },
    "environment": {"enum": ["production", "test", "demo", "development"]},
    "releaseChannel": {"enum": ["stable", "candidate", "development"]},
    "tier": {"enum": ["Core", "Operations", "Growth", "Control"]},
    "license": {
      "type": "object",
      "required": ["licenseId", "type", "status", "tenantLimit", "assignedTenants", "allowedTiers"],
      "properties": {
        "licenseId": {"type": "string"},
        "type": {"type": "string"},
        "status": {"const": "ACTIVE"},
        "validUntil": {"type": ["string", "null"]},
        "tenantLimit": {"type": "integer", "minimum": 1},
        "assignedTenants": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "allowedTiers": {"type": "array", "uniqueItems": true, "items": {"enum": ["Core", "Operations", "Growth", "Control"]}}
      }
    },
    "controls": {
      "type": "object",
      "required": ["selectedRecordOnly", "bulkExecution", "automaticRetry", "duplicateProtection", "proofLogRequired", "errorLogRequired", "ownerApprovalRequiredForExternalActions", "externalActionsEnabled"],
      "properties": {
        "selectedRecordOnly": {"const": true},
        "bulkExecution": {"const": false},
        "automaticRetry": {"const": false},
        "duplicateProtection": {"const": true},
        "proofLogRequired": {"const": true},
        "errorLogRequired": {"const": true},
        "ownerApprovalRequiredForExternalActions": {"const": true},
        "externalActionsEnabled": {"const": false}
      }
    },
    "featureFlags": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "core", "enabled"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "core": {"type": "boolean"},
          "enabled": {"type": "boolean"}
        }
      }
    },
    "roles": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
    "theme": {"type": "object"},
    "catalog": {"type": "object"},
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["mode", "credentialState", "executionState", "ownerReleaseRequired"],
        "properties": {
          "mode": {"type": "string"},
          "provider": {"type": ["string", "null"]},
          "credentialState": {"const": "NOT_CONFIGURED"},
          "executionState": {"const": "LOCKED"},
          "ownerReleaseRequired": {"const": true}
        }
      }
    },
    "data": {"type": "object"},
    "privacy": {"type": "object"},
    "support": {"type": "object"},
    "externalActionsEnabled": {"const": false}
  }
}
