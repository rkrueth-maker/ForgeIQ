    "acceptanceRequiresVersionMatch": true,
    "duplicateSendLock": true
  },
  "invoices": {
    "allowedStatuses": ["DRAFT", "OWNER_REVIEW", "APPROVED_TO_SEND", "SENT", "PARTIALLY_PAID", "PAID", "OVERDUE", "VOID", "CREDITED"],
    "sendEnabled": false,
    "paymentRequestsEnabled": false,
    "duplicateSendLock": true,
