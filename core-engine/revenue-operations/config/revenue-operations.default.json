    "csvExportEnabled": true,
    "apiSyncEnabled": false,
    "supportedExportFormats": ["GENERAL_LEDGER_CSV", "OPEN_INVOICES_CSV", "PAYMENTS_CSV", "EXPENSES_CSV", "PROFITABILITY_CSV"]
