  },
  "payments": {
    "providerHostedOnly": true,
    "rawCardDataAllowed": false,
    "processingEnabled": false,
    "refundExecutionEnabled": false,
    "manualRecordingEnabled": true,
    "approvedProviders": []
  },
  "communications": {
    "draftCreationEnabled": true,
